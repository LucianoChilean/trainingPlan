generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WorkoutEntry {
  id         Int      @id @default(autoincrement())
  exerciseId String
  micro      Int
  date       String
  weight     Float?
  sets       String   // JSON: "[10,10,9]"
  rpe        Int
  notes      String   @default("")
  savedAt    DateTime @default(now())

  @@index([exerciseId])
}
